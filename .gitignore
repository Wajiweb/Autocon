# ───────────────────────────────────────────────
# Environment / secrets — NEVER commit these
# ───────────────────────────────────────────────
.env
.env.*
!.env.example

# ───────────────────────────────────────────────
# Node dependencies — always regenerated by npm
# ───────────────────────────────────────────────
node_modules/
server/node_modules/
Autocon/node_modules/

# ───────────────────────────────────────────────
# Build outputs
# ───────────────────────────────────────────────
dist/
dist-ssr/
build/
Autocon/dist/

# ───────────────────────────────────────────────
# Logs
# ───────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ───────────────────────────────────────────────
# OS / Editor artifacts
# ───────────────────────────────────────────────
.DS_Store
Thumbs.db
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ───────────────────────────────────────────────
# IDE directories
# ───────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/

# ───────────────────────────────────────────────
# Misc
# ───────────────────────────────────────────────
*.local
