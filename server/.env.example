# AutoCon Backend Configuration Template
# DO NOT COMMIT ACTUAL SECRETS TO SOURCE CONTROL

# Server Setup
PORT=5000
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Database Connection (MongoDB URI)
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/autocon?retryWrites=true&w=majority

# Security (MUST BE AT LEAST 32 CHARS IN PRODUCTION)
JWT_SECRET=super_secret_development_key_change_me_in_production_123

# Web3 / Smart Contract Integration
RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_KEY
PRIVATE_KEY=0xYOUR_DEPLOYER_PRIVATE_KEY
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_KEY

# Background Workers (Redis)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Observability / Error Tracking
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# AI / Chat Integration (Gemini, OpenAI, etc)
GEMINI_API_KEY=AIzaSy...
